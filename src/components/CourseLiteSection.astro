---
/* CourseLiteSection.astro */
---

<section class="lite-course-section bg-white py-16">
  <div class="container mx-auto px-4 flex flex-col lg:flex-row items-center gap-12">
    
    <!-- 左側文字 -->
    <div class="text-center lg:text-left lg:w-1/2">
      <span class="inline-block bg-orange-100 text-orange-600 px-3 py-1 rounded-full text-sm mb-4">
        高嫚老師獨家統整系統
      </span>
      <h2 class="text-3xl lg:text-4xl font-bold mb-4">
        補齊英文斷層，
        <br />
        讓英文重新變成你累積得起來的能力
      </h2>
      <p class="text-gray-700 mb-6">
        高嫚老師獨家統整，專為曾經學過英文、中斷多年的成人學習者設計。
        <br />
        透過四個核心模組，英文重新回到可以吸收、記住、累積的狀態。
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
        <a href="#lite" class="bg-orange-600 text-white px-6 py-3 rounded-md hover:bg-orange-700 transition">
          立即開始使用 LITE 系統
        </a>
      </div>
    </div>

    <!-- 右側影片 + 模組 -->
    <div class="lg:w-1/2 relative">
      <div class="bg-gray-50 border border-gray-200 rounded-xl p-6 shadow-lg">
        <!-- 影片佔位 -->
        <div class="mb-6">
          <iframe
            class="w-full h-64 sm:h-80 rounded-lg"
            src="https://www.youtube.com/embed/YOUR_VIDEO_ID"
            title="LITE 課程影片"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
        <!-- 四個核心模組 -->
        <ul class="space-y-3 text-gray-800 font-medium">
          <li><span class="font-bold text-orange-600">L</span>｜邏輯發音對位</li>
          <li><span class="font-bold text-orange-600">I</span>｜結構化單字記憶</li>
          <li><span class="font-bold text-orange-600">T</span>｜戰略型筆記系統</li>
          <li><span class="font-bold text-orange-600">E</span>｜自動進步機制</li>
        </ul>
        <!-- 下方統計 -->
        <div class="flex justify-between mt-6 text-gray-500 text-sm">
          <div>98% 學員重新找回累積感</div>
          <div>35+ 主要服務年齡層</div>
        </div>
      </div>
      <div class="absolute top-0 right-0 bg-orange-600 text-white px-3 py-1 rounded-full text-xs font-semibold">
        最適合中年學習者
      </div>
    </div>
  </div>
</section>

<style>
  /* 可自行微調 Tailwind 類別，如果需要更多自訂 CSS 可以放這裡 */
</style>
