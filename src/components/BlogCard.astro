---
// src/components/BlogCard.astro
export interface Props {
  title:        string;
  description:  string;
  category:     string;
  pubDate:      Date;
  slug:         string;
  readingTime?: number;
  tags?:        string[];
}
const {
  title, description, category,
  pubDate, slug, readingTime, tags = [],
} = Astro.props;

const dateStr = pubDate.toLocaleDateString('zh-TW', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---
<a href={`/blog/${slug}/`} class="blog-card" aria-label={title}>
  <div class="card-img" aria-hidden="true">
    <span class="card-img-char">{title.charAt(0)}</span>
    <span class="card-cat">{category}</span>
  </div>
  <div class="card-body">
    <h3 class="card-title">{title}</h3>
    <p class="card-excerpt">{description}</p>
    <div class="card-meta">
      <time datetime={pubDate.toISOString()}>{dateStr}</time>
      {readingTime && <span aria-label={`閱讀需時 ${readingTime} 分鐘`}> · {readingTime} 分鐘閱讀</span>}
    </div>
  </div>
</a>

<style>
  .blog-card {
    background: #fff; border-radius: 12px; overflow: hidden;
    transition: all .26s; text-decoration: none; display: block;
    box-shadow: 0 2px 14px rgba(44,36,22,.05);
  }
  .blog-card:hover { transform: translateY(-5px); box-shadow: 0 12px 40px rgba(44,36,22,.11); }

  .card-img {
    width: 100%; height: 175px;
    background: linear-gradient(135deg, var(--brand-tan) 0%, #E0D0BC 100%);
    position: relative; display: flex; align-items: center; justify-content: center;
    overflow: hidden;
  }
  .card-img-char {
    font-family: 'Noto Serif TC', serif; font-size: 4.5rem; font-weight: 700;
    color: rgba(200,105,42,.18); user-select: none;
  }
  .card-cat {
    position: absolute; top: 14px; left: 14px;
    padding: 4px 10px; background: var(--brand-orange); color: #fff;
    font-size: .72rem; font-weight: 600; border-radius: 4px; letter-spacing: .05em;
  }
  .card-body    { padding: 22px 22px 24px; }
  .card-title   {
    font-family: 'Noto Serif TC', serif; font-size: 1.02rem; font-weight: 700;
    color: var(--brand-dark); line-height: 1.55; margin-bottom: 10px;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .card-excerpt {
    font-size: .84rem; color: var(--brand-mid-gray); line-height: 1.72; margin-bottom: 14px;
    display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
  }
  .card-meta { font-size: .77rem; color: var(--brand-light-gray); }
</style>
