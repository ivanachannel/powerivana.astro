---
// src/components/Header.astro
const NAV = [
  {
    label: '免費禮物下載',
    href: 'https://www.ivanakao.com/blogs/pdf',
    dropdown: [
      { label: '免費英文培訓課程', href: 'https://www.ivanachannel.com' },
      { label: '如何不恐懼說英文', href: 'https://reurl.cc/eWYeZj' },
      { label: '免費英文資源社群 SKOOL', href: 'https://www.skool.com/englishpower-5696/about' },
    ],
  },
  {
    label: '課程介紹',
    href: '/#course',
    dropdown: [
      { label: 'LITE 課程介紹', href: '/#course' },
      { label: '高嫚智本商城', href: 'https://shop.ivanakao.com' },
    ],
  },
  { label: '成果見證', href: '/testimonials' },
  { label: '高嫚專欄', href: '/blog' },
  {
    label: '關於高嫚',
    href: '/about/story',
    dropdown: [
      { label: '媒體報導', href: '/about/media' },
      { label: '高嫚故事', href: '/about/story' },
      { label: '聯繫高嫚', href: '/contact' },
    ],
  },
];
---

<header id="site-header">
  <div class="nav-container">
    <a href="/" class="logo-link">江臻冠英語高嫚老師</a>
    
    <nav class="desktop-nav-wrapper">
      <ul class="nav-list">
        {NAV.map(item => (
          <li class="nav-item">
            <a href={item.href} class="nav-link-main">{item.label}</a>
            {item.dropdown && (
              <ul class="nav-dropdown">
                {item.dropdown.map(sub => (
                  <li><a href={sub.href} target={sub.href.startsWith('http') ? "_blank" : "_self"}>{sub.label}</a></li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <button id="menu-trigger" class="hamburger-icon" aria-label="選單開關">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<div id="mobile-menu-drawer" class="mobile-drawer">
  <div class="drawer-header">
    <span class="drawer-logo">選單</span>
    <button id="close-trigger" class="close-btn">&times;</button>
  </div>
  <nav class="drawer-nav">
    {NAV.map(item => (
      <div class="drawer-item">
        <a href={item.href} class="drawer-link-top">{item.label}</a>
        {item.dropdown && (
          <div class="drawer-subs">
            {item.dropdown.map(sub => (
              <a href={sub.href} target={sub.href.startsWith('http') ? "_blank" : "_self"}>{sub.label}</a>
            ))}
          </div>
        )}
      </div>
    ))}
  </nav>
</div>

<div id="drawer-overlay" class="drawer-overlay"></div>

<style is:global>
  /* 基礎設定 */
  #site-header { position: fixed; top: 0; left: 0; width: 100%; height: 72px; background: #FDF9F4; z-index: 1000; border-bottom: 1px solid rgba(0,0,0,0.05); }
  .nav-container { max-width: 1200px; margin: 0 auto; height: 100%; display: flex; align-items: center; justify-content: space-between; padding: 0 24px; }
  .logo-link { font-weight: 700; color: #2C2416; text-decoration: none; font-size: 1.15rem; }

  /* 電腦版樣式 */
  .nav-list { display: flex; list-style: none; gap: 10px; margin: 0; padding: 0; }
  .nav-item { position: relative; padding: 10px 0; }
  .nav-link-main { color: #4A4035; text-decoration: none; font-weight: 500; padding: 8px 12px; transition: color 0.2s; }
  .nav-link-main:hover { color: #C8692A; }
  
  .nav-dropdown { position: absolute; top: 100%; left: 0; background: #FFF; min-width: 220px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); border-radius: 8px; padding: 10px 0; display: none; list-style: none; }
  .nav-item:hover .nav-dropdown { display: block; }
  .nav-dropdown a { display: block; padding: 10px 20px; color: #4A4035; text-decoration: none; font-size: 0.95rem; }
  .nav-dropdown a:hover { background: #FAF7F2; color: #C8692A; }

  /* 漢堡圖示 */
  .hamburger-icon { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 5px; }
  .hamburger-icon span { width: 24px; height: 2px; background: #2C2416; transition: 0.3s; }

  /* 手機版抽屜 */
  .mobile-drawer { position: fixed; top: 0; right: -320px; width: 300px; height: 100vh; background: #FDF9F4; z-index: 2001; transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1); padding: 20px; overflow-y: auto; }
  .mobile-drawer.active { right: 0; }
  .drawer-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; border-bottom: 1px solid #eee; padding-bottom: 15px; }
  .drawer-logo { font-weight: 700; color: #C8692A; }
  .close-btn { font-size: 2rem; background: none; border: none; cursor: pointer; color: #4A4035; line-height: 1; }
  .drawer-link-top { display: block; font-weight: 700; color: #2C2416; text-decoration: none; padding: 12px 0; font-size: 1.1rem; }
  .drawer-subs { padding-left: 15px; margin-bottom: 15px; }
  .drawer-subs a { display: block; padding: 8px 0; color: #4A4035; text-decoration: none; font-size: 1rem; }
  
  .drawer-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 2000; display: none; backdrop-filter: blur(2px); }
  .drawer-overlay.active { display: block; }

  /* 響應式切換點 */
  @media (max-width: 1024px) {
    .desktop-nav-wrapper { display: none; }
    .hamburger-icon { display: flex; }
  }
</style>

<script is:inline>
  function setupNavbar() {
    const trigger = document.getElementById('menu-trigger');
    const close = document.getElementById('close-trigger');
    const drawer = document.getElementById('mobile-menu-drawer');
    const overlay = document.getElementById('drawer-overlay');

    if (!trigger || !drawer || !overlay) return;

    const toggleMenu = (open) => {
      drawer.classList.toggle('active', open);
      overlay.classList.toggle('active', open);
      document.body.style.overflow = open ? 'hidden' : '';
    };

    trigger.onclick = () => toggleMenu(true);
    close.onclick = () => toggleMenu(false);
    overlay.onclick = () => toggleMenu(false);

    // 點擊連結後自動關閉（用於單頁錨點連動）
    drawer.querySelectorAll('a').forEach(link => {
      link.onclick = () => toggleMenu(false);
    });
  }

  document.addEventListener('DOMContentLoaded', setupNavbar);
  document.addEventListener('astro:page-load', setupNavbar);
</script>