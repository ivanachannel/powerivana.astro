---
// src/components/Header.astro
// ══════════════════════════════════════════════════════════════════════════════
// 導覽列（Navbar）- 質感漢堡選單升級版
// ══════════════════════════════════════════════════════════════════════════════
const NAV = [
  {
    id: 'gift',
    label: '免費禮物下載',
    href: 'https://www.ivanakao.com/blogs/pdf',
    external: true,
    dropdown: [
      { label: '免費英文培訓課程', href: 'https://www.ivanachannel.com', external: true },
      { label: '如何不恐懼說英文（免費攻略下載）', href: 'https://reurl.cc/eWYeZj', external: true },
      { label: '免費英文資源社群 SKOOL', href: 'https://www.skool.com/englishpower-5696/about', external: true },
    ],
  },
  {
    id: 'course',
    label: '課程介紹',
    href: '/#course',
    dropdown: [
      { label: 'LITE 課程介紹', href: '/#course' },
      { label: '高嫚智本商城', href: 'https://shop.ivanakao.com', external: true },
    ],
  },
  {
    id: 'testimonials',
    label: '成果見證',
    href: '/testimonials',
  },
  {
    id: 'blog',
    label: '高嫚專欄',
    href: '/blog',
  },
  {
    id: 'about',
    label: '關於高嫚',
    href: '/about/story',
    dropdown: [
      { label: '媒體報導', href: '/about/media' },
      { label: '高嫚故事', href: '/about/story' },
      { label: '聯繫高嫚', href: '/contact' },
    ],
  },
];

const LOGIN_ITEMS = [
  { label: '高嫚課程登入', href: 'https://sso.teachable.com/secure/1078310/identity/login/otp' },
  { label: '高嫚AI教練登入', href: 'https://ai.ivanakao.com' },
  { label: '高嫚社群SKOOL登入', href: 'https://www.skool.com/englishpower-5696/about' },
];
---

<nav id="navbar" role="navigation" aria-label="主選單">
  <div class="nav-inner">
    <a href="/" class="brand-name" aria-label="回到首頁 — 江臻冠英語高嫚老師">
      江臻冠英語高嫚老師
    </a>
    
    <ul class="nav-menu" role="menubar" aria-label="主選單">
      {NAV.map(item => (
        <li class="nav-item" role="none">
          {item.dropdown ? (
            <>
              <button class="nav-link" role="menuitem" aria-haspopup="true" aria-expanded="false" data-nav-btn>
                {item.label}
                <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                  <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <div class="dropdown" role="menu">
                {item.dropdown.map(sub => (
                  <a href={sub.href} role="menuitem" class="dropdown-item"
                    {...(sub.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
                    {sub.label}
                  </a>
                ))}
              </div>
            </>
          ) : (
            <a href={item.href} class="nav-link" role="menuitem"
              {...(item.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
              {item.label}
            </a>
          )}
        </li>
      ))}
    </ul>

    <div class="nav-right">
      <div class="nav-item login-wrap">
        <button class="btn-login" aria-haspopup="true" aria-expanded="false" data-nav-btn>
          學員登入
          <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="dropdown login-dropdown" role="menu">
          {LOGIN_ITEMS.map(item => (
            <a href={item.href} target="_blank" rel="noopener noreferrer" class="dropdown-item">
              {item.label}
            </a>
          ))}
        </div>
      </div>
      
      <button class="hamburger" id="hamburgerBtn" aria-label="開關行動選單" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</nav>

<div class="mobile-overlay" id="mobileOverlay"></div>

<div class="mobile-menu" id="mobileMenu" role="navigation" aria-label="行動選單" aria-hidden="true">
  <div class="mobile-menu-inner">
    
    <div class="mobile-section">
      <span class="mobile-link-title">免費禮物下載</span>
      <a href="https://www.ivanachannel.com" target="_blank" rel="noopener noreferrer" class="mobile-link">免費英文培訓課程</a>
      <a href="https://reurl.cc/eWYeZj" target="_blank" rel="noopener noreferrer" class="mobile-link">如何不恐懼說英文</a>
      <a href="https://www.skool.com/englishpower-5696/about" target="_blank" rel="noopener noreferrer" class="mobile-link">免費英文資源社群 SKOOL</a>
    </div>

    <div class="mobile-section">
      <span class="mobile-link-title">課程介紹</span>
      <a href="/#course" class="mobile-link">LITE 課程介紹</a>
      <a href="https://shop.ivanakao.com" target="_blank" rel="noopener noreferrer" class="mobile-link">高嫚智本商城</a>
    </div>

    <div class="mobile-section">
      <a href="/testimonials" class="mobile-link-main">成果見證</a>
      <a href="/blog" class="mobile-link-main">高嫚專欄</a>
    </div>

    <div class="mobile-section">
      <span class="mobile-link-title">關於高嫚</span>
      <a href="/about/media" class="mobile-link">媒體報導</a>
      <a href="/about/story" class="mobile-link">高嫚故事</a>
      <a href="/contact" class="mobile-link">聯繫高嫚</a>
    </div>

    <div class="mobile-divider"></div>
    
    <div class="mobile-section">
      <span class="mobile-link-title">學員登入</span>
      {LOGIN_ITEMS.map(item => (
        <a href={item.href} target="_blank" rel="noopener noreferrer" class="mobile-link">
          {item.label}
        </a>
      ))}
    </div>
    
  </div>
</div>

<style is:global>
  /* === 基礎重置與強制優先權 === */
  #navbar, .nav-inner, .nav-menu, .nav-item, .nav-link, .brand-name, .dropdown, .mobile-menu, .hamburger {
    box-sizing: border-box !important;
  }

  /* === 電腦版導覽列外觀 === */
  #navbar {
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    width: 100% !important;
    z-index: 1000 !important;
    background: rgba(253, 249, 244, 0.98) !important;
    backdrop-filter: blur(12px) !important;
    border-bottom: 1px solid rgba(200, 185, 168, 0.35) !important;
    display: block !important;
  }

  .nav-inner {
    max-width: 1280px !important;
    margin: 0 auto !important;
    padding: 0 32px !important;
    height: 68px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: space-between !important;
  }

  .brand-name {
    font-family: 'Noto Serif TC', serif !important;
    font-size: 1.08rem !important;
    font-weight: 700 !important;
    color: #2C2416 !important;
    text-decoration: none !important;
    white-space: nowrap !important;
  }

  .nav-menu {
    display: flex !important;
    flex-direction: row !important;
    align-items: center !important;
    gap: 6px !important;
    list-style: none !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  .nav-item {
    position: relative !important;
    display: block !important;
  }

  .nav-link, .btn-login {
    display: flex !important;
    align-items: center !important;
    gap: 4px !important;
    padding: 8px 13px !important;
    color: #4A4035 !important;
    text-decoration: none !important;
    font-weight: 500 !important;
    background: transparent !important;
    border: none !important;
    cursor: pointer !important;
    font-size: 1rem !important;
  }

  /* === 下拉選單 (滑鼠懸浮顯示) === */
  .dropdown {
    display: none !important; 
    position: absolute !important;
    top: 100% !important;
    left: 0 !important;
    background: #fff !important;
    min-width: 200px !important;
    box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important;
    padding: 8px 0 !important;
    border-radius: 8px !important;
    border: 1px solid rgba(200, 185, 168, 0.2) !important;
  }

  .nav-item:hover .dropdown,
  .login-wrap:hover .dropdown {
    display: block !important; 
  }

  .dropdown-item {
    display: block !important;
    padding: 10px 20px !important;
    color: #4A4035 !important;
    text-decoration: none !important;
    font-size: 0.95rem !important;
  }

  .dropdown-item:hover {
    color: #C8692A !important;
    background: #FAF7F2 !important;
  }

  /* =========================================
     手機版專屬樣式 (漢堡按鈕與側滑選單)
     ========================================= */
  
  /* 預設隱藏手機版元素 */
  .hamburger { display: none !important; }
  
  /* 手機版遮罩 */
  .mobile-overlay {
    display: none !important;
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    width: 100vw !important;
    height: 100vh !important;
    background: rgba(0, 0, 0, 0.4) !important;
    backdrop-filter: blur(2px) !important;
    z-index: 998 !important;
    opacity: 0 !important;
    transition: opacity 0.3s ease !important;
  }
  .mobile-overlay.active {
    display: block !important;
    opacity: 1 !important;
  }

  /* 側滑選單本體 */
  .mobile-menu {
    position: fixed !important;
    top: 0 !important;
    right: -100% !important; /* 初始位置在畫面右側外面 */
    width: 80% !important;
    max-width: 320px !important;
    height: 100vh !important;
    background: #FDF9F4 !important;
    z-index: 999 !important;
    box-shadow: -5px 0 25px rgba(0,0,0,0.1) !important;
    transition: right 0.4s cubic-bezier(0.4, 0, 0.2, 1) !important;
    overflow-y: auto !important;
  }
  
  .mobile-menu.active {
    right: 0 !important; /* 滑入畫面 */
  }

  .mobile-menu-inner {
    padding: 80px 24px 40px !important; /* 頂部留白給關閉按鈕 */
  }

  .mobile-section {
    margin-bottom: 24px !important;
  }

  .mobile-link-title {
    display: block !important;
    font-size: 0.85rem !important;
    font-weight: 700 !important;
    color: #C8692A !important;
    margin-bottom: 8px !important;
    letter-spacing: 0.05em !important;
  }

  .mobile-link-main {
    display: block !important;
    font-size: 1.1rem !important;
    font-weight: 600 !important;
    color: #2C2416 !important;
    text-decoration: none !important;
    padding: 10px 0 !important;
    border-bottom: 1px solid rgba(200, 185, 168, 0.3) !important;
  }

  .mobile-link {
    display: block !important;
    padding: 10px 0 10px 12px !important;
    color: #4A4035 !important;
    text-decoration: none !important;
    font-size: 1rem !important;
  }

  .mobile-divider {
    height: 1px !important;
    background: rgba(200, 185, 168, 0.3) !important;
    margin: 20px 0 !important;
  }

  /* 進入平板與手機尺寸時的變化 */
  @media (max-width: 1024px) {
    .nav-menu { display: none !important; } /* 隱藏電腦版選單 */
    .nav-right .login-wrap { display: none !important; } /* 隱藏電腦版登入按鈕 */
    
    /* 漢堡按鈕設計 */
    .hamburger { 
      display: flex !important;
      flex-direction: column !important;
      justify-content: space-around !important;
      width: 26px !important;
      height: 22px !important;
      background: transparent !important;
      border: none !important;
      cursor: pointer !important;
      padding: 0 !important;
      z-index: 1000 !important; /* 確保按鈕在選單之上 */
    }

    .hamburger span {
      width: 100% !important;
      height: 2px !important;
      background: #2C2416 !important;
      border-radius: 10px !important;
      transition: all 0.3s linear !important;
      position: relative !important;
      transform-origin: 1px !important;
    }

    /* 漢堡按鈕變成 X 的動畫 */
    .hamburger.active span:first-child { transform: rotate(45deg) !important; }
    .hamburger.active span:nth-child(2) { opacity: 0 !important; transform: translateX(20px) !important; }
    .hamburger.active span:nth-child(3) { transform: rotate(-45deg) !important; }
  }
</style>

<script is:inline>
  // 控制漢堡選單的開關邏輯
  (() => {
    const btn = document.getElementById('hamburgerBtn');
    const menu = document.getElementById('mobileMenu');
    const overlay = document.getElementById('mobileOverlay');

    if (!btn || !menu || !overlay) return;

    const toggleMenu = () => {
      // 切換 active 狀態
      const isActive = menu.classList.toggle('active');
      btn.classList.toggle('active');
      overlay.classList.toggle('active');
      
      // 當選單打開時，禁止背景畫面滾動
      document.body.style.overflow = isActive ? 'hidden' : '';
    };

    // 點擊漢堡按鈕觸發
    btn.addEventListener('click', toggleMenu);
    
    // 點擊暗色遮罩也能關閉選單
    overlay.addEventListener('click', toggleMenu);
  })();
</script>