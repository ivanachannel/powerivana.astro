---
// src/components/Header.astro
const NAV = [
  { label: '免費禮物下載', href: 'https://www.ivanakao.com/blogs/pdf' },
  { label: '課程介紹', href: '/#course' },
  { label: '成果見證', href: '/testimonials' },
  { label: '高嫚專欄', href: '/blog' },
  { label: '關於高嫚', href: '/about/story' }
];
---

<header class="main-header">
  <div class="header-inner">
    <a href="/" class="site-logo">江臻冠英語高嫚老師</a>
    
    <nav class="nav-pc">
      {NAV.map(item => (
        <a href={item.href} class="nav-item">{item.label}</a>
      ))}
    </nav>

    <button id="h-toggle" class="h-toggle">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<div id="side-menu" class="side-menu">
  <div class="menu-content">
    <button id="h-close" class="h-close">&times;</button>
    {NAV.map(item => (
      <a href={item.href} class="menu-link">{item.label}</a>
    ))}
  </div>
</div>

<style is:global>
  /* 鎖死頂部，不與其他組件衝突 */
  .main-header { position: fixed; top: 0; left: 0; width: 100%; height: 70px; background: #FDF9F4; z-index: 9999; border-bottom: 1px solid #eee; }
  .header-inner { max-width: 1200px; margin: 0 auto; height: 100%; display: flex; align-items: center; justify-content: space-between; padding: 0 20px; }
  .site-logo { font-weight: bold; color: #2C2416; text-decoration: none; font-size: 1.1rem; }
  
  /* 電腦版顯示，手機版隱藏 */
  .nav-pc { display: flex; gap: 20px; }
  .nav-item { color: #4A4035; text-decoration: none; font-weight: 500; }

  /* 漢堡圖示 (強制在 900px 以下出現) */
  .h-toggle { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 10px; }
  .h-toggle span { width: 25px; height: 2px; background: #2C2416; }

  /* 手機選單抽屜 */
  .side-menu { position: fixed; top: 0; right: -100%; width: 280px; height: 100vh; background: #FDF9F4; z-index: 10000; transition: 0.3s; box-shadow: -5px 0 15px rgba(0,0,0,0.1); }
  .side-menu.active { right: 0; }
  .menu-content { padding: 80px 30px; display: flex; flex-direction: column; gap: 20px; }
  .h-close { position: absolute; top: 20px; right: 20px; font-size: 2rem; border: none; background: none; cursor: pointer; }
  .menu-link { font-size: 1.2rem; font-weight: bold; color: #C8692A; text-decoration: none; }

  @media (max-width: 900px) {
    .nav-pc { display: none !important; }
    .h-toggle { display: flex !important; }
  }
</style>

<script is:inline>
  function initNav() {
    const btn = document.getElementById('h-toggle');
    const close = document.getElementById('h-close');
    const menu = document.getElementById('side-menu');
    if (btn && menu) {
      btn.onclick = () => menu.classList.add('active');
      close.onclick = () => menu.classList.remove('active');
    }
  }
  document.addEventListener('DOMContentLoaded', initNav);
  document.addEventListener('astro:page-load', initNav);
</script>