---
// src/components/TestimonialsSection.astro
import { getCollection } from 'astro:content';

const all      = await getCollection('testimonials');
const featured = all
  .filter(t => t.data.featured)
  .sort((a, b) => (a.data.sortOrder ?? 99) - (b.data.sortOrder ?? 99))
  .slice(0, 3);

// Fallback: if fewer than 3 featured, fill with others
const display = featured.length >= 3
  ? featured
  : all.sort((a, b) => (a.data.sortOrder ?? 99) - (b.data.sortOrder ?? 99)).slice(0, 3);
---
<section id="testimonials" aria-labelledby="testimonials-heading">
  <div class="t-inner">

    <div class="fade-in">
      <div class="section-label" style="color:rgba(224,122,58,.9);">成果見證</div>
      <h2 class="section-title" id="testimonials-heading" style="color:#FDF9F4;">
        以前一直學不起來，<br>後來終於找到能累積的方法
      </h2>
      <div class="divider"></div>
      <p class="section-sub" style="color:rgba(255,255,255,.55);">
        來自真實學員，用 LITE 系統重新建立英文能力的改變
      </p>
    </div>

    <div class="t-grid">
      {await Promise.all(display.map(async (t, i) => {
        const { Content } = await t.render();
        const initial = t.data.name.charAt(0);
        return (
          <article class={`t-card fade-in delay-${i}`} aria-label={`${t.data.name} 的見證`}>
            <div class="t-quote" aria-hidden="true">&ldquo;</div>
            <div class="t-body">
              <Content />
            </div>
            <footer class="t-person">
              <div class="t-avatar" aria-hidden="true">{initial}</div>
              <div>
                <div class="t-name">{t.data.name}</div>
                <div class="t-role">{t.data.role}</div>
                {t.data.result && (
                  <div class="t-result">{t.data.result}</div>
                )}
              </div>
            </footer>
          </article>
        );
      }))}
    </div>

    <div class="t-more fade-in">
      <a href="/testimonials/" class="t-more-btn">查看全部 21 則見證 →</a>
    </div>

  </div>
</section>

<style>
  section {
    padding: 96px 32px;
    background: var(--brand-section-dk);
  }
  .t-inner { max-width: 1100px; margin: 0 auto; }
  .t-grid  { display: grid; grid-template-columns: repeat(3, 1fr); gap: 26px; margin-top: 52px; }

  .t-card {
    background: rgba(255,255,255,.05); border: 1px solid rgba(255,255,255,.09);
    border-radius: 14px; padding: 34px 28px; transition: all .26s;
    display: flex; flex-direction: column;
  }
  .t-card:hover { background: rgba(255,255,255,.08); border-color: rgba(200,105,42,.35); transform: translateY(-3px); }
  .t-quote { font-size: 3rem; color: var(--brand-orange); line-height: 1; margin-bottom: 14px; opacity: .65; font-family: Georgia, serif; }
  .t-body  { font-size: .9rem; color: rgba(255,255,255,.8); line-height: 1.88; flex: 1; margin-bottom: 26px; }
  .t-body  p { margin-bottom: .7em; }
  .t-body  p:last-child { margin-bottom: 0; }

  .t-person { display: flex; align-items: center; gap: 14px; padding-top: 20px; border-top: 1px solid rgba(255,255,255,.09); }
  .t-avatar {
    width: 44px; height: 44px; border-radius: 50%;
    background: rgba(200,105,42,.28);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.1rem; color: var(--brand-orange); font-weight: 700;
    font-family: 'Noto Serif TC', serif; flex-shrink: 0;
  }
  .t-name   { font-size: .9rem; font-weight: 600; color: rgba(255,255,255,.9); }
  .t-role   { font-size: .77rem; color: rgba(255,255,255,.4); margin-top: 3px; }
  .t-result { font-size: .77rem; color: var(--brand-orange); margin-top: 4px; font-weight: 600; }

  .t-more     { text-align: center; margin-top: 46px; }
  .t-more-btn {
    display: inline-flex; align-items: center; justify-content: center;
    padding: 13px 34px; background: transparent; color: rgba(255,255,255,.8);
    border: 1.5px solid rgba(255,255,255,.22); border-radius: 8px;
    text-decoration: none; font-size: .95rem; font-weight: 600;
    transition: all .26s; font-family: 'Noto Sans TC', sans-serif;
  }
  .t-more-btn:hover { border-color: var(--brand-orange); color: var(--brand-orange); }

  @media (max-width: 900px) { .t-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .t-grid { grid-template-columns: 1fr; } section { padding: 64px 20px; } }
</style>
