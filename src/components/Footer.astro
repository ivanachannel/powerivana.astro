---

<footer role="contentinfo">
  <div class="footer-inner">

    <!-- Brand Column -->
    <div class="footer-brand">
      <h3 class="footer-brand-name">江臻冠英語<br>高嫚老師</h3>
      <p class="footer-brand-desc">
        高嫚老師獨家統整的成人英文補斷層系統，幫助離開英文多年的人，
        重新建立可以吸收、記住、累積的英文能力結構。
      </p>

      <!-- Social Icons（5個，必須清晰可辨） -->
      <div class="footer-socials" aria-label="社群媒體連結">
        {SOCIAL.map(s => (
          <a
            href={s.href}
            target="_blank"
            rel="noopener noreferrer"
            class="social-icon"
            aria-label={`前往高嫚 ${s.label}`}
            style={`--icon-color: ${s.color};`}
            set:html={s.svg}
          />
        ))}
      </div>

      <!-- 品牌生態系（僅頁尾） -->
      <div class="footer-ecosystem">
        <a
          href="https://shop.ivanakao.com"
          target="_blank"
          rel="noopener noreferrer"
          class="eco-link"
        >
          高嫚商城
        </a>
        <a
          href="https://www.wuraos.com"
          target="_blank"
          rel="noopener noreferrer"
          class="eco-link"
        >
          卓睛勝劵
        </a>
      </div>
    </div>

    <!-- Navigation Columns -->
    {FOOTER_COLS.map(col => (
      <div class="footer-col">
        <h4 class="footer-col-title">{col.title}</h4>
        {col.links.map(link => (
          <a
            href={link.href}
            class="footer-col-link"
            {...(link.ext ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            {link.label}
          </a>
        ))}
      </div>
    ))}

  </div>

  <!-- Bottom bar — 年份由 JS 動態填入 -->
  <div class="footer-bottom">
    <span id="footer-copyright">
      © <span id="footer-year"></span> 江臻冠英語高嫚老師 · All Rights Reserved
    </span>
    <span class="footer-domain">power.ivanakao.com</span>
  </div>
</footer>

<!-- 動態年份：JavaScript 實作 -->
<script is:inline>
  const yearEl = document.getElementById('footer-year');
  if (yearEl) yearEl.textContent = new Date().getFullYear();
</script>

<style>
  footer {
    background: var(--brand-dark);
    color: rgba(255,255,255,.5);
    padding: 56px 32px 32px;
  }
  .footer-inner {
    max-width: 1100px; margin: 0 auto;
    display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 48px;
    padding-bottom: 44px; border-bottom: 1px solid rgba(255,255,255,.07);
  }

  /* Brand */
  .footer-brand-name {
    font-family: 'Noto Serif TC', serif; font-size: 1.12rem; font-weight: 700;
    color: #FDF9F4; margin-bottom: 12px; line-height: 1.55;
  }
  .footer-brand-desc {
    font-size: .82rem; line-height: 1.85; max-width: 240px; margin-bottom: 22px;
  }

  /* Social icons */
  .footer-socials { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 20px; }
  .social-icon {
    width: 40px; height: 40px; border-radius: 9px;
    background: rgba(255,255,255,.07); border: 1px solid rgba(255,255,255,.1);
    display: flex; align-items: center; justify-content: center;
    color: rgba(255,255,255,.6); text-decoration: none;
    transition: all .22s; flex-shrink: 0;
  }
  .social-icon:hover {
    background: var(--icon-color, var(--brand-orange));
    border-color: transparent; color: #fff;
    transform: translateY(-2px);
    box-shadow: 0 4px 14px rgba(0,0,0,.25);
  }

  /* Ecosystem links */
  .footer-ecosystem { display: flex; gap: 10px; flex-wrap: wrap; }
  .eco-link {
    padding: 6px 15px; border-radius: 6px;
    background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1);
    color: rgba(255,255,255,.52); font-size: .8rem; font-weight: 600;
    text-decoration: none; transition: all .22s;
  }
  .eco-link:hover {
    background: rgba(200,105,42,.22);
    border-color: rgba(200,105,42,.35);
    color: var(--brand-orange-lt);
  }

  /* Nav columns */
  .footer-col-title {
    font-size: .87rem; font-weight: 700; color: rgba(255,255,255,.8);
    margin-bottom: 15px; letter-spacing: .05em;
  }
  .footer-col-link {
    display: block; font-size: .82rem; color: rgba(255,255,255,.46);
    text-decoration: none; margin-bottom: 9px; transition: color .2s;
  }
  .footer-col-link:hover { color: var(--brand-orange); }

  /* Bottom bar */
  .footer-bottom {
    max-width: 1100px; margin: 26px auto 0;
    display: flex; justify-content: space-between; align-items: center;
    font-size: .77rem; color: rgba(255,255,255,.26); flex-wrap: wrap; gap: 8px;
  }
  .footer-domain { font-family: monospace; letter-spacing: .04em; }

  /* Responsive */
  @media (max-width: 1024px) {
    .footer-inner { grid-template-columns: 1fr 1fr; gap: 32px; }
  }
  @media (max-width: 600px) {
    footer        { padding: 40px 20px 24px; }
    .footer-inner { grid-template-columns: 1fr; gap: 28px; }
    .footer-bottom{ flex-direction: column; text-align: center; }
  }
</style>
