---
import Layout from '../../../../layouts/BlogLayout.astro';    
import PostGrid from '../../../../components/PostGrid.astro';


const items = [
  {
    title: '示範文章標題一',
    image: '/images/blog/demo-10.jpg',
    description: '這裡之後放這些英文怎麼說文章摘要。',
    href: '/blog/english/how-to-say/demo-01',
  },
  {
    title: '示範文章標題二',
    image: '/images/blog/demo-11.jpg',
    description: '這裡之後放這些英文怎麼說文章摘要。',
    href: '/blog/english/how-to-say/demo-02',
  },
  {
    title: '示範文章標題三',
    image: '/images/blog/demo-12.jpg',
    description: '這裡之後放這些英文怎麼說文章摘要。',
    href: '/blog/english/how-to-say/demo-03',
  },
];
---

<Layout title="這些英文怎麼說">
  <section class="mx-auto max-w-7xl px-4 py-12 md:px-6 lg:py-16">
    <div class="max-w-3xl">
      <h1 class="text-3xl font-bold tracking-tight text-gray-900 md:text-5xl">
        這些英文怎麼說
      </h1>
      <p class="mt-4 text-base leading-7 text-gray-600 md:text-lg">
        把中文常見說法，轉成自然、實用的英文表達。
      </p>
    </div>
    <div class="mt-10">
      <PostGrid items={items} />
    </div>
  </section>
</Layout>