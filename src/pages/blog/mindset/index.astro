---
import Layout from '../../../layouts/Layout.astro';
import PostGrid from '../../../components/PostGrid.astro';

const items = [
  {
    title: '示範文章標題一',
    image: '/images/blog/demo-04.jpg',
    description: '這裡之後放精神指引文章摘要。',
    href: '/blog/mindset/demo-01',
  },
  {
    title: '示範文章標題二',
    image: '/images/blog/demo-05.jpg',
    description: '這裡之後放精神指引文章摘要。',
    href: '/blog/mindset/demo-02',
  },
  {
    title: '示範文章標題三',
    image: '/images/blog/demo-06.jpg',
    description: '這裡之後放精神指引文章摘要。',
    href: '/blog/mindset/demo-03',
  },
];
---

<Layout title="精神指引">
  <section class="mx-auto max-w-7xl px-4 py-12 md:px-6 lg:py-16">
    <div class="max-w-3xl">
      <h1 class="text-3xl font-bold tracking-tight text-gray-900 md:text-5xl">
        精神指引
      </h1>
      <p class="mt-4 text-base leading-7 text-gray-600 md:text-lg">
        給正在往前走的人，一套能穩住心態、持續成長的精神系統。
      </p>
    </div>

    <div class="mt-10">
      <PostGrid items={items} />
    </div>
  </section>
</Layout>