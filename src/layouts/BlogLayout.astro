---
// src/layouts/BlogLayout.astro
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description: string;
  pubDate?: Date;           // 改成可選
  category: string;
  tags?: string[];
  author?: string;
  readingTime?: number;
  canonical?: string;
  ogImage?: string;
}

const {
  title,
  description,
  pubDate,
  category,
  tags = [],
  author = '高嫚老師',
  readingTime,
  canonical,
  ogImage,
} = Astro.props;

// 安全處理日期
const dateStr = pubDate 
  ? pubDate.toLocaleDateString('zh-TW', {
      year: 'numeric', 
      month: 'long', 
      day: 'numeric'
    })
  : '';
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  ogType="article"
  pubDate={pubDate}
>
  <article style="padding-top: 96px; min-height: 80vh;">
    <div class="blog-wrap">
      <!-- Breadcrumb -->
      <nav class="blog-breadcrumb" aria-label="麵包屑">
        <a href="/">首頁</a>
        <span aria-hidden="true"> / </span>
        <a href="/blog/">高嫚專欄</a>
        <span aria-hidden="true"> / </span>
        <span>{category}</span>
      </nav>

      <!-- Header -->
      <header class="blog-header">
        <a href={`/blog/?cat=${category}`} class="blog-cat-badge">{category}</a>
        <h1 class="blog-post-title">{title}</h1>
        <div class="blog-meta">
          <span>{author}</span>
          <span aria-hidden="true">·</span>
          {dateStr && <time datetime={pubDate?.toISOString()}>{dateStr}</time>}
          {readingTime && (
            <>
              <span aria-hidden="true">·</span>
              <span>閱讀需時 {readingTime} 分鐘</span>
            </>
          )}
        </div>
        {tags.length > 0 && (
          <div class="blog-tags" role="list" aria-label="標籤">
            {tags.map(tag => (
              <span class="blog-tag" role="listitem">#{tag}</span>
            ))}
          </div>
        )}
      </header>

      <!-- Divider -->
      <div style="height:1px; background:var(--brand-tan); margin-bottom:44px;"></div>

      <!-- Body -->
      <div class="prose-ivana">
        <slot />
      </div>

      <!-- Footer -->
      <footer class="blog-post-footer">
        <a href="/blog/" class="back-link">← 返回高嫚專欄</a>
        <a href="https://www.ivanakao.com/blogs/pdf"
           target="_blank" rel="noopener noreferrer"
           class="btn-primary" style="font-size:.9rem; padding:11px 22px;">
          領取更多免費資源
        </a>
      </footer>
    </div>
  </article>
</BaseLayout>